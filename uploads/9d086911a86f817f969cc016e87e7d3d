// Wait for the DOM to be fully loaded
document.addEventListener('DOMContentLoaded', function() {
    // Create shimmer effects
    createShimmerEffects();
    
    // Add scroll animations
    initScrollAnimations();
    
    // Add interactive hover effects
    initHoverEffects();
});

/**
 * Creates the shimmer animation effects seen on Linear's website
 */
function createShimmerEffects() {
    // Create horizontal shimmer
    const horizontalShimmer = document.createElement('div');
    horizontalShimmer.classList.add('shimmer');
    horizontalShimmer.style.top = '0';
    horizontalShimmer.style.left = '0';
    horizontalShimmer.style.width = '100px';
    horizontalShimmer.style.height = '1px';
    document.body.appendChild(horizontalShimmer);
    
    // Create vertical shimmer
    const verticalShimmer = document.createElement('div');
    verticalShimmer.classList.add('shimmer');
    verticalShimmer.style.top = '0';
    verticalShimmer.style.right = '0';
    verticalShimmer.style.width = '1px';
    verticalShimmer.style.height = '100px';
    verticalShimmer.style.transform = 'translateY(-100%)';
    document.body.appendChild(verticalShimmer);
    
    // Animate vertical shimmer differently
    verticalShimmer.style.animation = 'shimmer 4s infinite';
    verticalShimmer.style.animationDelay = '1.5s';
}

/**
 * Initializes scroll-based animations
 */
function initScrollAnimations() {
    // Get all elements that should animate on scroll
    const animatedElements = document.querySelectorAll('.feature-card, .section-header, .hero-content, .app-interface');
    
    // Create an Intersection Observer
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
            }
        });
    }, { threshold: 0.1 });
    
    // Set initial styles and observe each element
    animatedElements.forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        observer.observe(el);
    });
}

/**
 * Initializes hover effects for interactive elements
 */
function initHoverEffects() {
    // Add subtle hover effect to navigation items
    const navItems = document.querySelectorAll('.main-nav a');
    navItems.forEach(item => {
        item.addEventListener('mouseenter', function() {
            this.style.opacity = '1';
        });
        item.addEventListener('mouseleave', function() {
            this.style.opacity = '0.7';
        });
    });
    
    // Add hover effect to feature cards
    const featureCards = document.querySelectorAll('.feature-card');
    featureCards.forEach(card => {
        card.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-5px)';
            this.style.backgroundColor = 'rgba(255, 255, 255, 0.05)';
        });
        card.addEventListener('mouseleave', function() {
            this.style.transform = 'translateY(0)';
            this.style.backgroundColor = 'rgba(255, 255, 255, 0.03)';
        });
    });
}

/**
 * Creates a dynamic gradient background animation
 * This simulates the subtle moving gradient seen on Linear's site
 */
function createDynamicGradient() {
    const gradientElement = document.querySelector('.gradient-background');
    if (!gradientElement) return;
    
    // Create canvas for gradient animation
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    
    // Set canvas size
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
    
    // Append canvas to gradient element
    gradientElement.appendChild(canvas);
    
    // Animation variables
    let time = 0;
    const colors = [
        { r: 100, g: 100, b: 255, a: 0.15 },
        { r: 255, g: 100, b: 100, a: 0.1 }
    ];
    
    // Animation function
    function animate() {
        time += 0.005;
        
        // Clear canvas
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        // Draw first gradient
        const gradient1 = ctx.createRadialGradient(
            canvas.width / 2 + Math.sin(time) * 200,
            canvas.height / 2 + Math.cos(time) * 100,
            0,
            canvas.width / 2 + Math.sin(time) * 200,
            canvas.height / 2 + Math.cos(time) * 100,
            canvas.width * 0.5
        );
        
        gradient1.addColorStop(0, `rgba(${colors[0].r}, ${colors[0].g}, ${colors[0].b}, ${colors[0].a})`);
        gradient1.addColorStop(1, 'rgba(0, 0, 0, 0)');
        
        ctx.fillStyle = gradient1;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        // Draw second gradient
        const gradient2 = ctx.createRadialGradient(
            canvas.width / 2 + Math.cos(time) * 200,
            canvas.height / 2 + Math.sin(time) * 100,
            0,
            canvas.width / 2 + Math.cos(time) * 200,
            canvas.height / 2 + Math.sin(time) * 100,
            canvas.width * 0.4
        );
        
        gradient2.addColorStop(0, `rgba(${colors[1].r}, ${colors[1].g}, ${colors[1].b}, ${colors[1].a})`);
        gradient2.addColorStop(1, 'rgba(0, 0, 0, 0)');
        
        ctx.fillStyle = gradient2;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        requestAnimationFrame(animate);
    }
    
    // Start animation
    animate();
    
    // Handle window resize
    window.addEventListener('resize', function() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    });
}

// Initialize dynamic gradient after page load
window.addEventListener('load', createDynamicGradient);

/**
 * Adds keyboard shortcut functionality similar to Linear's website
 */
function initKeyboardShortcuts() {
    document.addEventListener('keydown', function(e) {
        // Command/Ctrl + K to open search (simulated)
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            alert('Search shortcut activated (Cmd/Ctrl + K)');
        }
        
        // Escape to close modals (simulated)
        if (e.key === 'Escape') {
            // Close any open modals here
            console.log('Escape pressed - would close modals');
        }
    });
}

// Initialize keyboard shortcuts
initKeyboardShortcuts();